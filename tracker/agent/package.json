{
  "name": "laptop-tracker-agent",
  "version": "1.0.0",
  "description": "Device tracking agent for Laptop Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.yourorg.laptop-tracker",
    "productName": "Laptop Tracker",
    "files": ["main.js", "preload.js", "login.html", "geo.html"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.productivity" },
    "linux": { "target": "AppImage" }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
